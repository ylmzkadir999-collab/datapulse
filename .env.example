# DataPulse v5 — Environment Variables
# Kopyala: cp .env.example .env

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=change-me-in-production-min-32-chars

# CORS: Frontend URL(s), comma separated
ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# ── Redis (Upstash on Railway) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...anon-key
SUPABASE_SERVICE_KEY=eyJ...service-role-key
SUPABASE_BUCKET=datapulse-files

# ── Claude AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── İyzico ───────────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Cost Guardrails (USD per job) ────────────────────────────
COST_LIMIT_FREE=0.005
COST_LIMIT_STARTER=0.05
COST_LIMIT_PRO=1.0

# ── Preview System ───────────────────────────────────────────
PREVIEW_ROWS=10
